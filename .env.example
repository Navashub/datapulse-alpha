# Application
APP_NAME=DataPulse AI
APP_VERSION=0.1.0
DEBUG=True

# PostgreSQL — update with your credentials
DATABASE_URL=postgresql://postgres:password@localhost:5432/datapulse_db

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# LanceDB — local folder where vectors are stored
LANCEDB_URI=./lancedb_data

# Document storage
DOCUMENTS_DIR=./documents